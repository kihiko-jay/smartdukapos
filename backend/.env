# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DukaPOS
APP_VERSION=4.1.0
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dukapos:dukapos_pass@localhost:5432/dukapos_db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_-hex_32

# PATCH C-03: Protects /health/deep and /metrics in production
# Generate with: openssl rand -hex 32  Leave blank in dev.
INTERNAL_API_KEY=

# Sync agent authentication — REQUIRED (endpoints return 503 if not set)
# Must match CLOUD_API_KEY in sync-agent/.env
# Generate with: openssl rand -hex 32


# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=300

# Redis (optional — if set, enables multi-worker rate limiting)
# REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── M-PESA (Daraja API) ───────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/mpesa/callback
MPESA_ENV=sandbox

# HMAC secret for Daraja callback signature verification (defence-in-depth)
# Generate with: openssl rand -hex 32  — configure the same value in Daraja portal
MPESA_WEBHOOK_SECRET=

# ── KRA eTIMS ─────────────────────────────────────────────────────────────────
# sandbox: https://etims-sbx-api.kra.go.ke/etims-api
# production: https://etims-api.kra.go.ke/etims-api
ETIMS_URL=https://etims-sbx-api.kra.go.ke/etims-api
ETIMS_PIN=
ETIMS_BRANCH_ID=00
ETIMS_DEVICE_SERIAL=

# ── Store ─────────────────────────────────────────────────────────────────────
STORE_NAME=My Duka Store
STORE_LOCATION=Nairobi, Kenya
VAT_RATE=0.16
CURRENCY=KES

# ── Redis ──────────────────────────────────────────────────────────────────────
# Enables: distributed rate limiting (multi-worker safe) + product cache
# Leave blank in dev to use in-process fallback automatically
# Generate password with: openssl rand -hex 32

REDIS_URL=redis://redis:6379/0
# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Leave blank to disable. Install sentry-sdk if you set this.
SENTRY_DSN=

# ── Database backup ───────────────────────────────────────────────────────────
# Used by scripts/backup.sh


# Optional — upload to S3 if set:
# AWS_S3_BACKUP_BUCKET=s3://my-company-dukapos-backups
# Slack webhook for failure alerts:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Server ────────────────────────────────────────────────────────────────────
# Number of uvicorn worker processes (production: match vCPU count)


