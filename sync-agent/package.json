{
  "name": "dukapos-sync-agent",
  "version": "4.0.0",
  "description": "DukaPOS local sync agent — bridges legacy local DB to cloud backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test tests/sync-agent.test.js",
    "test:watch": "node --test --watch tests/sync-agent.test.js",
    "lint": "eslint src/ tests/ --max-warnings=0",
    "pm2:start": "pm2 start src/index.js --name dukapos-sync --time",
    "pm2:stop": "pm2 stop dukapos-sync",
    "pm2:restart": "pm2 restart dukapos-sync",
    "pm2:logs": "pm2 logs dukapos-sync"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "axios-retry": "^4.4.0",
    "better-queue": "^3.8.12",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "dotenv": "^16.4.5",
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}