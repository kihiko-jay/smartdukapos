# ── Local legacy database (READ-ONLY connection) ───────────────────────────
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=dukapos_db
LOCAL_DB_USER=dukapos
LOCAL_DB_PASS=dukapos_pass

# ── Cloud backend API ──────────────────────────────────────────────────────
CLOUD_API_URL=https://api.yourdomain.com/api/v1
CLOUD_API_KEY=your-sync-agent-api-key   # dedicated read/write key for sync agent

# ── Polling intervals (seconds) ────────────────────────────────────────────
SYNC_INTERVAL_PRODUCTS=60
SYNC_INTERVAL_CUSTOMERS=60
SYNC_INTERVAL_TRANSACTIONS=10   # transactions need near-real-time sync
SYNC_INTERVAL_EMPLOYEES=300

# ── Batch sizes ────────────────────────────────────────────────────────────
BATCH_SIZE=500                  # max records per sync cycle

# ── Store identity ─────────────────────────────────────────────────────────
STORE_ID=1
TERMINAL_ID=T01

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # debug | info | warn | error
LOG_FILE=logs/sync-agent.log

# ── Checkpoint storage (v4.1) ───────────────────────────────────────────────
# Defaults to /app/data/checkpoints.json inside the mounted data volume.
# Override this only for local development outside Docker.
# CHECKPOINT_DIR=/app/data
